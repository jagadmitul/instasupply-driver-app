# ===========================================
# InstaSupply Driver App — Environment Config
# ===========================================

# Google Maps API Key (enable Directions API in Google Cloud Console)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase Config (download google-services.json from Firebase Console)
# Place google-services.json in project root for Android
# Place GoogleService-Info.plist in project root for iOS

# Firebase project details (for reference, actual config is in google-services.json)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_firebase_app_id
